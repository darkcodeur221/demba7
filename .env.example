# Contact form (Resend). Copy this file to .env.local and fill in.
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# "From" address. The domain must be verified in your Resend account.
CONTACT_FROM="Portfolio <contact@deejitcorp.com>"

# Where contact messages are delivered.
CONTACT_TO=demba@deejitcorp.com
